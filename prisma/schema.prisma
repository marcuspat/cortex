generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// AUTHENTICATION MODELS (NextAuth.js)
// ===========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // User's data
  connectors    Connector[]
  memories      Memory[]
  chatSessions  ChatSession[]
  insightCards  InsightCard[]
  settings      Setting[]
  agentTraces   AgentTrace[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================================
// APPLICATION MODELS
// ===========================================

model Connector {
  id        String   @id @default(cuid())
  type      String   // gmail, github, obsidian, notion, calendar, drive, slack, filesystem
  name      String
  status    String   @default("disconnected") // disconnected, connecting, active, error
  config    String   @default("{}") // JSON config
  lastSync  DateTime?
  itemCount Int      @default(0)
  error     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories  Memory[]

  @@index([userId])
}

model Memory {
  id           String   @id @default(cuid())
  content      String
  title        String   @default("")
  sourceType   String   // email, code, note, document, chat, calendar, bookmark
  connectorId  String?
  connector    Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  chunkIndex   Int      @default(0)
  tags         String   @default("[]") // JSON array
  metadata     String   @default("{}") // JSON metadata
  accessCount  Int      @default(0)
  relevanceScore Float  @default(0)
  sourceTimestamp DateTime @default(now())
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entities MemoryEntity[]

  @@index([userId])
}

model InsightCard {
  id          String   @id @default(cuid())
  title       String
  claim       String
  type        String   // connection, reminder, draft, summary, suggestion
  status      String   @default("pending") // pending, surfaced, acted, dismissed, expired
  action      String?  // suggested action text
  feedback    String?  // useful, not_useful, already_knew
  agentType   String   @default("connector") // which agent generated it
  priority    Int      @default(5) // 1-10
  memoryIds   String   @default("[]") // JSON array of cited memory IDs
  expiresAt   DateTime?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String        @default("New Conversation")
  userId    String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String   // user, assistant
  content    String
  memoryIds  String   @default("[]") // JSON array of cited memory IDs
  createdAt  DateTime @default(now())
}

model AgentTrace {
  id          String   @id @default(cuid())
  agentType   String   // indexer, researcher, connector, drafter, planner, orchestrator
  status      String   // running, completed, failed
  input       String   @default("{}") // JSON input
  output      String?  // JSON output
  memoryIds   String   @default("[]") // JSON array
  error       String?
  durationMs  Int      @default(0)
  steps       String   @default("[]") // JSON array of trace steps
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Entity {
  id           String   @id @default(cuid())
  name         String
  type         String   // person, project, repository, document, organization
  canonicalName String  @default("")
  aliases      String   @default("[]") // JSON array
  metadata     String   @default("{}") // JSON metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memories     MemoryEntity[]
}

model MemoryEntity {
  id        String   @id @default(cuid())
  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  role      String   @default("mentioned") // mentioned, primary, author, assignee

  @@unique([memoryId, entityId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String
  value     String   @default("")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@index([userId])
}

// ===========================================
// AUDIT LOGGING
// ===========================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String   // create, update, delete, sync, login, logout, export
  resourceType String   // Connector, Memory, InsightCard, ChatSession, Setting, AgentTrace
  resourceId   String?
  changes      String   @default("{}") // JSON before/after values or created data
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  errorMessage String?
  metadata     String   @default("{}") // JSON additional context
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}
